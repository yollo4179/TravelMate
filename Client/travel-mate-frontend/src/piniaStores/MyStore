import { defineStore } from 'pinia'
import { ref, computed } from 'vue'

export const useUserStore = defineStore('user', () => {
  // 1. 제네릭(<User | null>) 제거
  const userDesc = ref(null)

  const isAuthenticated = computed(() => userDesc.value !== null)

  const nickname = computed(() => userDesc.value?.nickname || 'unknown')
  const role = computed(() => userDesc.value?.role || 'unknown')
  const userId = computed(() => userDesc.value?.userId || 'unknown')
  const email = computed(() => userDesc.value?.email || 'unknown')
  const profileImageUrl = computed(() => userDesc.value?.profileImageUrl || '')

  // 2. 파라미터 타입(: User) 제거
  function setUser(data) {
    userDesc.value = data
  }

  function logout() {
    userDesc.value = null
  }

  return {
    userDesc,
    isAuthenticated,
    setUser,
    logout,
    nickname,
    role,
    userId,
    email,
    profileImageUrl,
  }
})
